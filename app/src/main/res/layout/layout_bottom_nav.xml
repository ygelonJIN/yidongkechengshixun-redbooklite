<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottomNav"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@color/white"
    android:elevation="0dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:stateListAnimator="@null"
    android:translationZ="0dp">

    <TextView
        android:id="@+id/tvTabHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/tab_home"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTabMarket"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/tab_market"
        android:textColor="@color/nav_inactive"
        android:textSize="14sp" />

    <FrameLayout
        android:id="@+id/tabPublish"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:contentDescription="@string/select_cover"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_post" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/tabMessage"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tvTabMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/tab_message"
            android:textColor="@color/nav_inactive"
            android:textSize="14sp" />

        <View
            android:id="@+id/viewMessageDot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_gravity="center"
            android:layout_marginStart="22dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_message_dot" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvTabMe"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/tab_me"
        android:textColor="@color/nav_inactive"
        android:textSize="14sp" />
</LinearLayout>
